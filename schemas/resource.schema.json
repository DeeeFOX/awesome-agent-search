{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Search Resource Registry",
  "type": "object",
  "required": ["resources"],
  "properties": {
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "ecosystem",
          "summary",
          "path",
          "tags",
          "maturity",
          "public"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "type": {
            "type": "string",
            "enum": ["integration", "best-practice", "research", "tool", "reference"]
          },
          "ecosystem": {
            "type": "string",
            "enum": ["codex", "claude-code", "openclaw", "generic", "multi-agent"]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          },
          "language": {
            "type": "string",
            "enum": ["en", "zh-CN"]
          },
          "translationOf": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|/)\\.\\.(/|$)).+$"
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "maturity": {
            "type": "string",
            "enum": ["starter", "recommended", "advanced", "experimental"]
          },
          "public": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
